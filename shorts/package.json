{
  "name": "appch-shorts",
  "version": "0.1.0",
  "private": true,
  "description": "中国語フレーズ・ショート動画の自動生成パイプライン（appchアプリと単語データ共有）",
  "type": "module",
  "scripts": {
    "build": "node scripts/build-today.mjs",
    "render": "node scripts/render.mjs",
    "today": "node scripts/build-today.mjs && node scripts/render.mjs",
    "build:ura": "node scripts/build-ura.mjs",
    "render:ura": "node scripts/render-ura.mjs",
    "today:ura": "node scripts/gen-sfx.mjs && node scripts/build-ura.mjs && node scripts/render-ura.mjs",
    "sfx": "node scripts/gen-sfx.mjs",
    "studio": "remotion studio",
    "upload": "node scripts/upload-all.mjs"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/google-fonts": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "pinyin-pro": "^3.28.1",
    "pngjs": "^7.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "typescript": "^5.5.0"
  }
}
